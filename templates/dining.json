{
  "id": "dining",
  "name": "Dining Out",
  "icon": "🍽️",
  "backgroundImage": "assets/dining_bg.png",
  "background": {
    "shapes": [
      {"type": "rect", "x": 0, "y": 0, "w": 800, "h": 600, "fill": "none", "stroke": "#ccc", "label": "restaurant"},
      {"type": "rect", "x": 0, "y": 400, "w": 800, "h": 200, "fill": "none", "stroke": "#aaa", "label": "floor"},
      {"type": "rect", "x": 250, "y": 250, "w": 300, "h": 150, "fill": "none", "stroke": "#999", "label": "table"},
      {"type": "rect", "x": 50, "y": 50, "w": 150, "h": 120, "fill": "none", "stroke": "#bbb", "label": "window"},
      {"type": "rect", "x": 600, "y": 50, "w": 150, "h": 120, "fill": "none", "stroke": "#bbb", "label": "kitchen"},
      {"type": "rect", "x": 350, "y": 10, "w": 100, "h": 30, "fill": "none", "stroke": "#ddd", "label": "sign"}
    ]
  },
  "elements": [
    {"type": "friend",  "id": "dining_cashier", "asset": "assets/dining_cashier.png", "label": "Cashier", "dimension": "spatial"},
    {"type": "friend",  "id": "dining_parent",  "asset": "assets/dining_parent.png",  "label": "Parent",  "dimension": "spatial"},
    {"type": "balloon", "id": "dining_tray",    "asset": "assets/dining_tray.png",    "label": "Tray",    "dimension": "decoration"},
    {"type": "cake",    "id": "dining_burger",  "asset": "assets/dining_burger.png",  "label": "Burger",  "dimension": "decoration"},
    {"type": "present", "id": "dining_fries",   "asset": "assets/dining_fries.png",   "label": "Fries",   "dimension": "decoration"},
    {"type": "lights",  "id": "dining_drink",   "asset": "assets/dining_drink.png",   "label": "Drink",   "dimension": "decoration"}
  ],
  "animations": {
    "friend":  ["wave"],
    "balloon": ["float"],
    "cake":    ["glow"],
    "present": ["shake"],
    "lights":  ["twinkle"]
  }
}
