{
  "id": "dining",
  "name": "Dining Out",
  "icon": "🍽️",
  "backgroundImage": "assets/dining_bg.png",
  "background": {
    "shapes": [
      {"type": "rect", "x": 0, "y": 0, "w": 800, "h": 600, "fill": "none", "stroke": "#ccc", "label": "restaurant"},
      {"type": "rect", "x": 0, "y": 400, "w": 800, "h": 200, "fill": "none", "stroke": "#aaa", "label": "floor"},
      {"type": "rect", "x": 250, "y": 250, "w": 300, "h": 150, "fill": "none", "stroke": "#999", "label": "table"},
      {"type": "rect", "x": 50, "y": 50, "w": 150, "h": 120, "fill": "none", "stroke": "#bbb", "label": "window"},
      {"type": "rect", "x": 600, "y": 50, "w": 150, "h": 120, "fill": "none", "stroke": "#bbb", "label": "kitchen"},
      {"type": "rect", "x": 350, "y": 10, "w": 100, "h": 30, "fill": "none", "stroke": "#ddd", "label": "sign"}
    ]
  },
  "elements": [
    {"type": "friend",  "id": "dining_diner1", "asset": "assets/friend1.png", "label": "Diner",  "dimension": "spatial"},
    {"type": "friend",  "id": "dining_diner2", "asset": "assets/friend2.png", "label": "Diner",  "dimension": "spatial"},
    {"type": "friend",  "id": "dining_diner3", "asset": "assets/friend3.png", "label": "Diner",  "dimension": "spatial"},
    {"type": "balloon", "id": "dining_plate",  "asset": "assets/dining_plate.png",  "label": "Plate",  "dimension": "decoration"},
    {"type": "present", "id": "dining_cup",    "asset": "assets/dining_cup.png",    "label": "Cup",    "dimension": "decoration"},
    {"type": "cake",    "id": "dining_pasta",  "asset": "assets/dining_pasta.png",  "label": "Pasta",  "dimension": "decoration"}
  ],
  "animations": {
    "friend":  ["wave"],
    "balloon": ["float"],
    "cake":    ["glow"],
    "present": ["shake"],
    "lights":  ["twinkle"]
